{
  "name": "study-hub",
  "version": "1.0.0",
  "description": "Personal knowledge + AI-powered study system",
  "main": "backend/server.js",
  "scripts": {
    "start":      "node backend/server.js",
    "dev":        "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"nodemon backend/server.js\" \"vite\"",
    "dev:api":    "nodemon backend/server.js",
    "dev:ui":     "vite",
    "build":      "vite build",
    "preview":    "vite preview",
    "setup":      "node scripts/setup.js",
    "db:init":    "node scripts/db-init.js",
    "db:reset":   "node scripts/db-reset.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.6",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.11.5",
    "unpdf": "^1.6.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.0",
    "vite": "^6.3.3"
  }
}

